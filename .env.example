# ============================================
# StoryFlow - AI Story Video Generator
# 复制此文件为 .env 并填入你的 API Keys
# cp .env.example .env
# ============================================

# --- TTS 语音合成（必填，选一个）---

# 提供商: stepfun / minimax
TTS_PROVIDER=stepfun

# 选项A: StepFun（阶跃星辰）TTS
# 注册获取: https://platform.stepfun.com
STEPFUN_API_KEY=your_stepfun_api_key_here
TTS_MODEL=step-tts-2
TTS_VOICE=cixingnansheng
TTS_SPEED=1.15
TTS_VOLUME=1.0
TTS_SAMPLE_RATE=24000

# 选项B: MiniMax TTS（TTS_PROVIDER=minimax 时生效）
# 注册获取: https://platform.minimaxi.com
MINIMAX_TTS_MODEL=speech-01-hd
MINIMAX_TTS_VOICE_ID=male-qn-jingying
MINIMAX_TTS_SPEED=1.15

# --- LLM 大语言模型（必填，用于生成故事稿）---

# 支持任意 OpenAI 兼容 API: DeepSeek / Kimi / OpenAI / 通义千问 等
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- AI 配图（二选一）---

# 选项A: MiniMax AI 生图
# 注册获取: https://platform.minimaxi.com
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_IMAGE_MODEL=image-01

# 选项B: Unsplash 免费图库
# 注册获取: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# 图片来源: minimax / unsplash / local
IMAGE_SOURCE=minimax

# --- 视频设置 ---

# 画面比例: 16:9（横屏/B站）或 9:16（竖屏/抖音）
ASPECT_RATIO=9:16

# 如果用本地图片（IMAGE_SOURCE=local），指定目录
LOCAL_IMAGE_DIR=./local_images
